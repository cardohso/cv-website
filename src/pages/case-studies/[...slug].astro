---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const studies = await getCollection('caseStudies', ({ data }) => !data.draft);
  return studies.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, summary, role, stack, status } = entry.data;
---

<BaseLayout title={`${title} — João Cardoso`} description={summary}>
  <article class="mx-auto max-w-3xl px-6 py-16 sm:py-24">
    <a
      href="/#projects"
      class="inline-flex items-center gap-1.5 text-sm font-medium text-muted transition-colors hover:text-accent"
    >
      <span aria-hidden="true">←</span>
      Back to projects
    </a>

    <header class="mt-8 border-b border-border pb-8">
      {
        status && (
          <p class="font-mono text-xs font-medium uppercase tracking-wider text-accent">
            {status}
          </p>
        )
      }
      <h1
        class="mt-3 text-3xl font-bold tracking-tight text-fg sm:text-4xl"
      >
        {title}
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-muted">{summary}</p>

      {
        role && (
          <p class="mt-4 text-sm text-muted">
            <span class="font-medium text-fg">Role:</span> {role}
          </p>
        )
      }

      {
        stack.length > 0 && (
          <ul class="mt-5 flex flex-wrap gap-2" aria-label="Stack">
            {stack.map((item) => (
              <li class="rounded-full border border-border px-2.5 py-1 font-mono text-xs text-muted">
                {item}
              </li>
            ))}
          </ul>
        )
      }
    </header>

    <div
      class="prose prose-zinc mt-10 max-w-none dark:prose-invert prose-headings:tracking-tight prose-a:text-accent prose-code:font-mono prose-code:text-sm prose-pre:border prose-pre:border-border prose-pre:bg-bg-soft prose-pre:text-fg"
    >
      <Content />
    </div>
  </article>
</BaseLayout>
