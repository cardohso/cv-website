---
import Section from './Section.astro';
import { getContent } from '../i18n';

const t = getContent();
const { about, profile } = t;
---

<Section id="about" heading={about.heading}>
  <div class="grid grid-cols-1 gap-10 sm:grid-cols-[200px_1fr] sm:gap-12">
    <!-- Profile photo slot. Swap /public/profile-placeholder.svg for a real
         photo and update `profile.photo` in src/i18n/en.ts. -->
    <div class="reveal">
      <img
        src={profile.photo}
        alt={about.photoAlt}
        width="200"
        height="200"
        loading="lazy"
        decoding="async"
        class="aspect-square w-40 rounded-xl border border-border object-cover sm:w-full"
      />
    </div>

    <div class="reveal flex flex-col gap-4">
      {
        about.paragraphs.map((paragraph) => (
          <p class="max-w-2xl text-base leading-relaxed text-muted">
            {paragraph}
          </p>
        ))
      }
    </div>
  </div>
</Section>
