---
import Section from './Section.astro';
import { getContent } from '../i18n';

const t = getContent();
const { writing } = t;
---

<Section id="writing" heading={writing.heading} intro={writing.intro}>
  <ul class="flex flex-col gap-4">
    {
      writing.items.map((item) => {
        const hasLink = Boolean(item.href);
        return (
          <li class="reveal">
            <article class="group relative flex flex-col rounded-xl border border-border bg-bg-soft p-6 transition-colors hover:border-accent">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <span class="font-mono text-xs font-medium uppercase tracking-wider text-accent">
                  {item.venue}
                </span>
                {item.status && (
                  <span class="rounded-full border border-border px-2 py-0.5 font-mono text-xs text-muted">
                    {item.status}
                  </span>
                )}
              </div>

              <h3 class="mt-3 text-lg font-semibold tracking-tight text-fg">
                {hasLink ? (
                  <a
                    href={item.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="after:absolute after:inset-0"
                  >
                    {item.title}
                  </a>
                ) : (
                  item.title
                )}
              </h3>

              <p class="mt-2 text-sm leading-relaxed text-muted">
                {item.description}
              </p>

              <p class="mt-4 text-sm font-medium text-accent">
                {hasLink ? (
                  <span class="inline-flex items-center gap-1.5">
                    Read the paper
                    <span
                      aria-hidden="true"
                      class="transition-transform group-hover:translate-x-0.5"
                    >
                      →
                    </span>
                  </span>
                ) : (
                  /* No public link yet — see PLACEHOLDERS / src/i18n/en.ts */
                  <span class="text-muted">Link coming when public</span>
                )}
              </p>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
